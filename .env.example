# Copy this file to .env and fill in deployment values locally. Never commit .env.
MESHYCODE_BASE_URL=https://your-openai-compatible-gateway.example/v1
MESHYCODE_API_KEY=

# Initial task routing. Adjust after model benchmark results.
NOVEL_MODEL_PLANNER=gpt-5.5
# gpt-5.6-sol is the validated primary for first drafts and compression.
# gpt-5.5 remains available through NOVEL_MODEL_DRAFTER as a fallback/benchmark.
NOVEL_MODEL_DRAFTER=gpt-5.5
NOVEL_MODEL_REWRITER=gpt-5.6-sol
NOVEL_MODEL_REVIEWER=gpt-5.5
NOVEL_MODEL_STATE=gpt-5.5
NOVEL_MODEL_CODE=gpt-5.3-codex-spark

# The gateway may expose these aliases intermittently. They are not placed in
# the automatic route until a probe confirms an available channel.
NOVEL_MODEL_OPTIONAL_DRAFTER=claude-sonnet-5
NOVEL_MODEL_OPTIONAL_STATE=claude-haiku-4-5
MESHYCODE_USER_AGENT=Mozilla/5.0 (compatible; NovelWorkflowRunner/0.2)
