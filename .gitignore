# Python bytecode and tool caches
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pyre/
.hypothesis/
.tox/
.nox/

# Coverage output
.coverage
.coverage.*
coverage.xml
htmlcov/

# Local environments and secrets
.env
.env.*
!.env.example
.envrc
.venv/
venv/
env/

# Packaging and build output
build/
dist/
*.egg-info/

# Local novel runs contain prompts, drafts, API logs and active locks.
# Completed, sanitized regression evidence belongs in test/matrix-runs/ and is committed.
/runs/

# Raw provider/task logs can contain deployment metadata and are not needed for
# published regression evidence; aggregated review metrics remain committed.
/test/matrix-runs/*/data/logs/

# Local agent/editor state
/.agents/
/.codex/
.idea/
.vscode/
*.code-workspace

# Temporary and operating-system files
*.log
*.tmp
*.temp
*.bak
*.swp
*~
.DS_Store
Thumbs.db
Desktop.ini
