{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "run.schema.json",
  "title": "Novel run",
  "type": "object",
  "required": ["schema_version", "run_id", "status", "last_committed_chapter", "provider", "policies"],
  "properties": {
    "schema_version": {"type": "string"},
    "run_id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,63}$"},
    "status": {"enum": ["planning", "ready", "running", "paused", "completed", "failed"]},
    "current_story_unit": {"type": ["string", "null"]},
    "current_batch": {"type": ["string", "null"]},
    "last_committed_chapter": {"type": "integer", "minimum": 0},
    "provider": {"type": "object"},
    "policies": {"type": "object"}
  },
  "additionalProperties": true
}
